# Dependencias
node_modules/

# Variables de entorno (credenciales; no subir a repositorio)
.env
.env.local
.env.*.local

# Subidas de usuarios (opcional: quitar si quieres versionar ejemplos)
uploads/*
!uploads/.gitkeep

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime / OS
.DS_Store
Thumbs.db

